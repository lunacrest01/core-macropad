{
    "manufacturer": "Braxon",
    "keyboard_name": "core",
    "maintainer": "braxon",
    "development_board": "kb2040",
    "diode_direction": "COL2ROW",

    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
        "encoder": true,
        "rgblight": true
    },

    "matrix_pins": {
        "rows": ["GP3", "GP4", "GP5"],
        "cols": ["GP0", "GP1", "GP2"]
    },

    "ws2812": {
        "pin": "GP8"
    },

    "rgblight": {
        "led_count": 8,
        "layers": {
            "enabled": true
        }
    },

    "encoder": {
        "rotary": [
            { "pin_a": "GP6", "pin_b": "GP7" }
        ]
    },

    "usb": {
        "vid": "0x6272",
        "pid": "0x2372",
        "device_version": "1.0.0"
    },

    "layouts": {
        "LAYOUT_ortho_3x3": {
            "layout": [
                { "matrix": [0, 0], "x": 0, "y": 0 },
                { "matrix": [0, 1], "x": 1, "y": 0 },
                { "matrix": [0, 2], "x": 2, "y": 0 },

                { "matrix": [1, 0], "x": 0, "y": 1 },
                { "matrix": [1, 1], "x": 1, "y": 1 },
                { "matrix": [1, 2], "x": 2, "y": 1 },

                { "matrix": [2, 0], "x": 0, "y": 2 },
                { "matrix": [2, 1], "x": 1, "y": 2 },
                { "matrix": [2, 2], "x": 2, "y": 2 }
            ]
        }
    }
}
